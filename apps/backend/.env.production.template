# ─────────────────────────────────────────────────────────────
#  JATRAMELA BACKEND — PRODUCTION ENVIRONMENT
#  Copy this to .env on your server. Fill ALL values.
# ─────────────────────────────────────────────────────────────

# ── CORS (replace with your actual domains) ──────────────────
STORE_CORS=https://jatramela.in,https://www.jatramela.in
ADMIN_CORS=https://admin.jatramela.in,https://jatramela.in
AUTH_CORS=https://jatramela.in,https://www.jatramela.in

# ── Database (use Neon / Supabase / Railway Postgres) ────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/jatramela?sslmode=require
DB_NAME=jatramela

# ── Redis (use Upstash free tier) ────────────────────────────
REDIS_URL=rediss://USER:PASSWORD@HOST:PORT

# ── JWT & Cookie secrets (generate with: openssl rand -hex 32)
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_STRING
COOKIE_SECRET=REPLACE_WITH_64_CHAR_RANDOM_STRING

# ── Razorpay LIVE keys (get from dashboard.razorpay.com) ─────
RAZORPAY_ID=rzp_live_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
RAZORPAY_ACCOUNT=your-razorpay-account-id
RAZORPAY_WEBHOOK_SECRET=REPLACE_WITH_WEBHOOK_SECRET

# ── Email (Resend.com — free 3000 emails/month) ──────────────
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXX
EMAIL_FROM=hello@jatramela.in

# ── Shiprocket (shiprocket.in) ───────────────────────────────
SHIPROCKET_EMAIL=your@email.com
SHIPROCKET_PASSWORD=your_shiprocket_password

# ── Storage (Cloudinary free tier for product images) ────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Admin ─────────────────────────────────────────────────────
MEDUSA_ADMIN_EMAIL=venkatesh@jatramela.in
MEDUSA_ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# ── General ───────────────────────────────────────────────────
NODE_ENV=production
PORT=9000
